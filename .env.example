# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public Provisioning API
# Shared secret the external sales panel (Convex) must send as the X-API-Key header.
NAMA_PUBLIC_API_KEY=

# Analytics (optional)
NAMA_LOG_LEVEL=info

# Domain Preview (local testing only)
# When "true", the root site honors ?preview_domain=<domain> to render a
# provisioned workspace regardless of the real Host header. Leave UNSET in
# production/customer-facing deployments so it can never accidentally work.
VITE_ENABLE_DOMAIN_PREVIEW=

# App
# NOTE: Do NOT set NODE_ENV here. This file is often copied to `.env` for deploys,
# and a `NODE_ENV=development` value forces Vite/Nitro into a development build
# (React DEV JSX transform + production React runtime), which crashes SSR on Vercel
# with "jsxDEV is not a function". Production builds infer NODE_ENV from the build
# command (`vite build`) automatically.
